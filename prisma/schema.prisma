generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId    String  @id
  firstName String
  lastName  String?
  avatar    String?
  email     String  @unique

  userInfo          UserInfo?
  communityInvites  CommunityInvite[]
  communities       CommunityMember[]
  courses           Course[]
  watchProgresses   WatchProgress[]
  enrollments       Enrollment[]
  lessonCompletions LessonCompletion[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UserInfo {
  userId      String @id
  username    String @unique
  phonenumber String @unique

  isHidden Boolean @default(true)
  alias    String

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Community {
  id   String @id @default(cuid())
  slug String @unique
  name String

  logo        String?
  description String?
  slogan      String?

  communityMembers CommunityMember[]
  communityInvites CommunityInvite[]
  courses          Course[]
  sessions         Session[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CommunityMember {
  id          String @id @default(cuid())
  userId      String
  communityId String

  role Role @default(STUDENT)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, communityId])
  @@index([userId])
  @@index([communityId])
}

model CommunityInvite {
  id          String  @id @default(cuid())
  token       String  @unique @default(nanoid())
  communityId String
  inviterId   String?

  limit Int? @default(10)
  joins Int  @default(0)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  inviter   User?     @relation(fields: [inviterId], references: [userId], onDelete: SetNull)

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([communityId])
  @@index([inviterId])
}

model Course {
  id          String  @id @default(cuid())
  slug        String
  title       String
  description String?
  imageUrl    String
  isActive    Boolean @default(false)

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Restrict)

  instructorId String?
  instructor   User?   @relation(fields: [instructorId], references: [userId], onDelete: SetNull)

  modules     Module[]
  enrollments Enrollment[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([slug, communityId])
}

model Module {
  id    String @id @default(cuid())
  title String
  slug  String
  index Float

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  lessons Lesson[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([slug, courseId])
  @@unique([courseId, index])
}

model Lesson {
  id    String     @id @default(cuid())
  slug  String
  title String
  index Float
  type  LessonType

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  sessionId String?  @unique
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  video Video?

  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lessonCompletions LessonCompletion[]

  @@unique([moduleId, index])
  @@unique([moduleId, slug])
  @@index([moduleId])
}

model Session {
  id           String        @id @default(cuid())
  title        String
  description  String?
  scheduledAt  DateTime
  duration     Int?
  platformLink String?
  status       SessionStatus @default(UPCOMING)

  lesson Lesson?

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  recording Recording?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([communityId])
  @@index([status])
  @@index([scheduledAt])
}

model Video {
  id          String  @id @default(cuid())
  description String?
  videoUrl    String?
  fileKey     String?
  duration    Int?

  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  watchProgress WatchProgress[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Recording {
  id          String  @id @default(cuid())
  title       String
  description String?
  videoUrl    String? // YouTube
  fileKey     String? // B2 Upload
  duration    Int?
  chapters    Json?

  sessionId String  @unique
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  watchProgress WatchProgress[]

  deletedAt   DateTime?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WatchProgress {
  id      String @id @default(cuid())
  percent Int    @default(0)

  completedAt   DateTime?
  lastWatchedAt DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  videoId String?
  video   Video?  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  recordingId String?
  recording   Recording? @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, videoId])
  @@unique([userId, recordingId])
  @@index([userId])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  completedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Enrollment {
  id          String    @id @default(cuid())
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

enum Role {
  OWNER
  ADMIN
  MODERATOR
  INSTRUCTOR
  STUDENT
}

enum SessionStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum LessonType {
  VIDEO
  SESSION
}
